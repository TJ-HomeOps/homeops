{
  "name": "Asset",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "LXC",
        "VM",
        "Docker Container",
        "Physical Server",
        "NAS",
        "Network Device",
        "Switch",
        "Firewall",
        "Router",
        "UPS",
        "Other"
      ]
    },
    "hostname": {
      "type": "string"
    },
    "ip_address": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Online",
        "Offline",
        "Maintenance",
        "Unknown"
      ],
      "default": "Online"
    },
    "health": {
      "type": "string",
      "enum": [
        "Healthy",
        "Warning",
        "Critical"
      ],
      "default": "Healthy"
    },
    "role": {
      "type": "string",
      "enum": [
        "Infrastructure",
        "Network",
        "Security",
        "Media",
        "Storage",
        "Development",
        "Automation",
        "Monitoring",
        "Other"
      ],
      "default": "Other"
    },
    "project": {
      "type": "string",
      "relationType": "one-to-one",
      "relationEntity": "Project"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "vmid": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "relationType": "one-to-one",
      "relationEntity": "InfrastructureProvider"
    },
    "node": {
      "type": "string"
    },
    "power_state": {
      "type": "string",
      "enum": [
        "Running",
        "Stopped",
        "Paused",
        "Unknown"
      ],
      "default": "Unknown"
    },
    "cpu_allocation": {
      "type": "number"
    },
    "ram_allocation": {
      "type": "number"
    },
    "disk_allocation": {
      "type": "number"
    },
    "archived": {
      "type": "boolean",
      "default": false
    },
    "archive_date": {
      "type": "string",
      "format": "date-time"
    },
    "archive_reason": {
      "type": "string"
    },
    "last_known_state": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "type"
  ]
}