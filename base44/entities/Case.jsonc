{
  "name": "Case",
  "type": "object",
  "properties": {
    "case_number": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "Low",
        "Normal",
        "High",
        "Critical"
      ],
      "default": "Normal"
    },
    "status": {
      "type": "string",
      "enum": [
        "Open",
        "In Progress",
        "Waiting",
        "Closed"
      ],
      "default": "Open"
    },
    "maintenance_window": {
      "type": "string",
      "enum": [
        "Immediate",
        "Scheduled",
        "Emergency",
        "Planned"
      ],
      "default": "Immediate"
    },
    "estimated_completion": {
      "type": "string",
      "format": "date"
    },
    "resolution_notes": {
      "type": "string"
    },
    "assigned_to": {
      "type": "string"
    },
    "asset": {
      "type": "string",
      "relationType": "one-to-one",
      "relationEntity": "Asset"
    },
    "project": {
      "type": "string",
      "relationType": "one-to-one",
      "relationEntity": "Project"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}