{
  "name": "Project",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Planning",
        "On Hold",
        "Completed",
        "Archived"
      ],
      "default": "Active"
    },
    "color": {
      "type": "string",
      "default": "#0EA5E9"
    }
  },
  "required": [
    "name"
  ]
}